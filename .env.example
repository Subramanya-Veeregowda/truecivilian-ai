# ==========================================
# TrueCivilian AI — Comprehensive Env Config
# ==========================================

# 1. Google Gemini AI Engine
# Required for server-side multi-modal classification, description drafting, and duplicate evaluation.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# 2. Database (PostgreSQL) Integration
DB_HOST="YOUR_POSTGRESQL_HOST"
DB_PORT="5432"
DB_NAME="truecivilian"
DB_USER="postgres"
DB_PASSWORD="YOUR_DATABASE_PASSWORD"

# 3. Security (JWT Authentication)
JWT_SECRET_KEY="YOUR_SECURE_JWT_SECRET_KEY_MUST_BE_AT_LEAST_256_BITS"

# 4. Cloudinary (Media Assets Platform)
CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"

# 5. Location Services (Google Maps Platform)
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_PLATFORM_KEY"

# 6. Hosting & Callback Links
APP_URL="YOUR_HOSTED_FRONTEND_URL"
BACKEND_URL="YOUR_HOSTED_BACKEND_URL"
